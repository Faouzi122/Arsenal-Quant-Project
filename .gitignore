# Global .gitignore file for the repository

# Ignore everything by default
*

# Whitelist the new Arsenal Quant API codebase
!/API_Factory/
!/API_Factory/Sentiment_Alpha_v1/
!/API_Factory/Sentiment_Alpha_v1/**

# Whitelist the open-source scripts
!/Antigravity_System/
!/Antigravity_System/scripts/
!/Antigravity_System/scripts/abi_guardrail.py
!/Antigravity_System/06_Router_MCP/
!/Antigravity_System/06_Router_MCP/**
!/Antigravity_System/01_Orchestrator_Grosz/
!/Antigravity_System/01_Orchestrator_Grosz/memory.md
!/Antigravity_System/01_Orchestrator_Grosz/02_discipline_fabuleuse.md
!/Antigravity_System/04_Strategy_Gerber/
!/Antigravity_System/04_Strategy_Gerber/Audit_Factory/
!/Antigravity_System/04_Strategy_Gerber/Audit_Factory/**
!/Antigravity_System/02_Developer_UncleBob/
!/Antigravity_System/02_Developer_UncleBob/**

# Exclude virtual environments, environment secrets, and caches inside whitelisted folders
**/venv/
**/.venv/
**/__pycache__/
**/*.pyc
**/.env
**/.env.local
**/.idea/
**/.vscode/
**/server.log
