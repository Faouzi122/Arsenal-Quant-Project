# Arsenal Decision Engine — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Ghost Protocol §8: this file uses public variable names only.

# =============================================================================
# DECISION ENGINE
# =============================================================================

# Primary REST API subscription key (X-API-Key header on /analyze/* endpoints)
# Generate a strong random key: python3 -c "import secrets; print(secrets.token_hex(32))"
ENGINE_API_KEY=change-me-generate-a-strong-random-key

# Port exposed to the host (Cloudflare Tunnel proxies this internally)
PORT=8002

# RSS market intelligence scan interval in seconds (default: 900 = 15 min)
SENSOR_INTERVAL=900

# =============================================================================
# PAYMENT GATEWAY — L402 / Lightning Network (§9)
# Self-hosted LNbits on Docker internal network (http://lnbits:5000)
# =============================================================================

# LNbits Invoice key (NOT the Admin key — least privilege principle)
# Get it from: http://localhost:5001 → your wallet → API Keys → Invoice/read key
LNBITS_INVOICE_KEY=

# LNbits URL — internal Docker network (do not change for Docker deployment)
# For standalone deployment: http://localhost:5000/api/v1
LNBITS_URL=http://lnbits:5000/api/v1

# Server-side HMAC secret for macaroon signing — KEEP THIS SECRET
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
GATEWAY_SECRET_KEY=change-me-generate-a-strong-random-key

# =============================================================================
# LNBITS BACKEND — FUNDING SOURCE
# =============================================================================
# Development / Test: leave LNBITS_BACKEND_WALLET_CLASS as FakeWallet (default)
# The FakeWallet simulates Lightning but generates no real invoices.
#
# Production options:
#   LND (self-hosted Lightning Node Daemon):
#     LNBITS_BACKEND_WALLET_CLASS=LndRestWallet
#     LND_REST_ENDPOINT=https://your-lnd-node:8080
#     LND_REST_CERT=/data/tls.cert
#     LND_REST_MACAROON=/data/invoice.macaroon.hex
#
#   CLN (Core Lightning):
#     LNBITS_BACKEND_WALLET_CLASS=CoreLightningWallet
#     CCLIGHTNING_RPC=/run/lightningd/lightning-rpc
#
#   Voltage (managed LND — production SaaS):
#     LNBITS_BACKEND_WALLET_CLASS=LndRestWallet
#     LND_REST_ENDPOINT=https://your-node.voltage.cloud:8080
#     LND_REST_MACAROON=<hex-encoded invoice macaroon>
#
LNBITS_BACKEND_WALLET_CLASS=FakeWallet
LND_REST_ENDPOINT=
LND_REST_CERT=
LND_REST_MACAROON=
CCLIGHTNING_RPC=
