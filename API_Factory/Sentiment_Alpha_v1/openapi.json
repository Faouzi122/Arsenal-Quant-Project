                "summary": "Execute Mcp Tool",
                "description": "Point d'ex\u00e9cution automatique pour les agents IA autonomes.",
                "operationId": "execute_mcp_tool_mcp_v1_tools_execute_post",
                "parameters": [
                    {
                        "name": "x-api-key",
                        "in": "header",
                        "required": false,
                        "schema": {
                            "anyOf": [
