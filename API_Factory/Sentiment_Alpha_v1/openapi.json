                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "title": "Response Analyze Maritime Risk Analyze Maritime Post"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/analyze/compare": {
            "post": {
                "summary": "Compare Corridors Risk",
                "description": "Compares the Transpacific and Suez Europe corridors to identify arbitrage opportunities.",
                "operationId": "compare_corridors_risk_analyze_compare_post",
                "requestBody": {
