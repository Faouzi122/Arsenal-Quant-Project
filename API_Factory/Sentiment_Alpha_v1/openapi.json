    },
    "paths": {
        "/analyze": {
            "post": {
                "summary": "Analyze Market Mood",
                "description": "Standard Financial Fear & Greed Index.",
                "operationId": "analyze_market_mood_analyze_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
