                }
            }
        },
        "/analyze/arbitrage": {
            "post": {
                "tags": [
                    "Decision Engine"
                ],
                "summary": "Evaluate Arbitrage Opportunity",
                "description": "**Quantitative Arbitrage Decision Engine** \u2014 GEMINI.md \u00a74 + Quantitative Decision Matrix.\n\nEvaluates a DeFi arbitrage opportunity through 6 sequential filters:\n- F1: Risk/Reward asymmetry \u2265 3:1\n- F2: Breakout confirmation (4H/Daily close above resistance)\n- F3: Volume anomaly V_24h > SMA(V,20) + 2\u03c3\n- F4: ATR positive slope over 3 consecutive periods\n- F5: Funding rate < 0.05% per 8h (long squeeze guard)\n- F6: Stop-loss node mandatory (capital preservation rule)\n\nThen computes R_net = Y_yield + I_incentives \u2212 IL \u2212 G_gas \u2212 S_MEV \u2212 F_funding.\nProposes EXECUTE only if R_net > flash_loan_opportunity_cost AND all 6 filters pass.",
                "operationId": "evaluate_arbitrage_opportunity_analyze_arbitrage_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ArbitrageInput"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "title": "Response Evaluate Arbitrage Opportunity Analyze Arbitrage Post"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/.well-known/mcp/server-card.json": {
            "get": {
                "tags": [
                    "MCP Bridge"
                ],
                "summary": "Get Server Card",
                "description": "MCP Server Card \u2014 A2A agent discovery endpoint (Ghost Protocol compliant).\nLoaded from static mcp-server.json. No internal names exposed.\nCompatible with Google ADK, LangChain, Composio, and MCP-aware agents.",
                "operationId": "get_server_card__well_known_mcp_server_card_json_get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    }
                }
            }
        },
