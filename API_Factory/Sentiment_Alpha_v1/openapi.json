                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "title": "Response Analyze Market Mood Analyze Post"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
